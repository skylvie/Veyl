{
    "name": "@skylvi/veyl",
    "version": "2.3.0",
    "private": false,
    "keywords": [
        "obfuscation",
        "obfuscator"
    ],
    "description": "A complete and customizable JavaScript and TypeScript obfuscation utility",
    "author": {
        "name": "Sylvie Rain",
        "email": "admin@skylvi.net",
        "url": "https://skylvi.net"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/skylvie/veyl.git"
    },
    "homepage": "https://github.com/skylvie/veyl#readme",
    "bugs": {
        "url": "https://github.com/skylvie/veyl/issues",
        "email": "admin@skylvi.net"
    },
    "license": "MIT",
    "type": "module",
    "files": [
        "dist/**/*",
        "package.json"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "pnpm --filter @skylvi/veyl-config build && rm -rf dist && tsc --project tsconfig.json",
        "typecheck": "pnpm --filter @skylvi/veyl-config build && tsc --project tsconfig.json --noEmit"
    },
    "dependencies": {
        "@skylvi/veyl-config": "workspace:*",
        "@babel/generator": "^7.29.1",
        "@babel/parser": "^7.29.2",
        "@babel/traverse": "^7.29.0",
        "@babel/types": "^7.29.0",
        "esbuild": "^0.28.0"
    }
}
