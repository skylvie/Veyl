{
    "name": "@skylvi/veyl",
    "version": "1.3.3",
    "type": "module",
    "private": false,
    "files": [
        "dist/**/*",
        "package.json"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "rm -rf dist && tsc --project tsconfig.json",
        "typecheck": "tsc --project tsconfig.json --noEmit"
    },
    "dependencies": {
        "@babel/generator": "^7.29.1",
        "@babel/parser": "^7.29.2",
        "@babel/traverse": "^7.29.0",
        "@babel/types": "^7.29.0",
        "esbuild": "^0.28.0"
    }
}
