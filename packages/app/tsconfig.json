{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "jsx": "react-jsx",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "types": ["vite/client"],
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "paths": {
            "@skylvi/veyl/browser": ["../core/src/browser.ts"],
            "@skylvi/veyl-config/browser": ["../config/src/browser.ts"]
        },
        "noEmit": true
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"]
}
