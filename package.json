{
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "pnpm -r build",
        "start": "node packages/cli/dist/cli.js",
        "typecheck": "pnpm -r typecheck",
        "lint": "biome lint packages",
        "lint:fix": "biome lint --write packages",
        "format": "biome format --write packages",
        "check": "biome check --write packages",
        "test": "zsh ./test/test.sh",
        "cloc": "cloc --exclude-dir=dist,node_modules --exclude-lang=YAML ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/babel__generator": "^7.27.0",
        "@types/babel__traverse": "^7.28.0",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
}