{
    "name": "@skylvi/veyl",
    "version": "1.2.9",
    "type": "module",
    "private": false,
    "bin": {
        "veyl": "./dist/cli.js"
    },
    "files": [
        "dist/**/*",
        ".gitignore",
        "LICENSE",
        "package.json",
        "pnpm-lock.yaml",
        "README.md",
        "tsconfig.json"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc --project tsconfig.json",
        "start": "node dist/cli.js",
        "typecheck": "tsc --project tsconfig.json --noEmit",
        "lint": "biome lint src",
        "lint:fix": "biome lint --write src",
        "format": "biome format --write src",
        "check": "biome check --write src",
        "test": "zsh ./test/test.sh",
        "cloc": "cloc --exclude-dir=dist,node_modules --exclude-lang=YAML ."
    },
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "@babel/generator": "^7.29.1",
        "@babel/parser": "^7.29.2",
        "@babel/traverse": "^7.29.0",
        "@babel/types": "^7.29.0",
        "chalk": "^5.6.2",
        "esbuild": "^0.28.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/babel__generator": "^7.27.0",
        "@types/babel__traverse": "^7.28.0",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
}