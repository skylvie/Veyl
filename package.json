{
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "pnpm -r build",
        "cli": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; node packages/cli/dist/index.js \"$@\"' --",
        "dev": "pnpm --filter @skylvi/veyl-app dev",
        "preview": "pnpm --filter @skylvi/veyl-app preview",
        "typecheck": "pnpm -r typecheck",
        "lint": "biome lint packages",
        "lint:fix": "biome lint --write packages",
        "format": "biome format --write packages",
        "check": "biome check --write packages",
        "test": "node tests/runner.mjs",
        "cloc": "cloc --exclude-dir=dist,node_modules --exclude-lang=YAML ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.12",
        "@types/babel__generator": "^7.27.0",
        "@types/babel__traverse": "^7.28.0",
        "@types/node": "^25.6.0",
        "typescript": "^6.0.2"
    }
}
